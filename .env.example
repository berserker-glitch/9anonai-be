# ===== REQUIRED =====
OPENROUTER_API_KEY=sk-or-v1-your-key-here
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
DB_URL=mysql://root:password@localhost:3306/qanonai

# ===== PADDLE (billing) =====
PADDLE_API_KEY=your-paddle-api-key
PADDLE_SANDBOX=true
PADDLE_PRICE_BASIC=pri_01your-basic-price-id
PADDLE_PRICE_PRO=pri_01your-pro-price-id
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
# Return URL after checkout — must be an approved domain in Paddle dashboard
# Leave unset for local dev (Paddle uses default payment link domain)
# Set to https://9anonai.com/pricing?status=success in production
PADDLE_RETURN_URL=

# ===== EMAIL (Resend) =====
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=9anon AI <noreply@9anonai.com>

# ===== OPTIONAL =====
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
