datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  image         String?
  personalization String? @db.Text
  marketingSource String?
  isOnboarded     Boolean   @default(false)
  feedbackDismissed Boolean @default(false) // Whether user has dismissed the feedback form modal
  dismissedTips   String?   @db.Text        // JSON array of dismissed tip IDs
  role          String    @default("user")  // "user" | "superadmin"
  lastLoginAt   DateTime?                   // Timestamp of most recent login
  lastActiveAt  DateTime?                   // Timestamp of most recent chat message
  createdAt     DateTime  @default(now())
  chats         Chat[]
  files         UserFile[]
  documents     GeneratedDocument[]
  contractSessions ContractSession[]
}

model Chat {
  id         String    @id @default(cuid())
  title      String
  isPinned   Boolean   @default(false)
  shareToken String?   @unique  // Public share token for read-only link
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  role      String
  content   String   @db.Text
  sources   String?  @db.Text
  attachmentUrl String? // Link to generated PDF
  attachmentName String? 
  files         String?  @db.Text // JSON array: [{id, url, name, mimetype, size}]
  feedback  String?  // "like" | "dislike" | null
  parentId  String?  // For regeneration versioning
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model UserFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimetype     String
  size         Int
  path         String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model GeneratedDocument {
  id        String   @id @default(cuid())
  type      String   // "employment", "rental", "nda", "service", etc.
  title     String
  filename  String
  path      String
  metadata  String?  @db.Text // JSON of contract details
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Contract Builder Models
// ─────────────────────────────────────────────────────────────────────────────

/** Tracks a contract drafting session with live HTML, review notes, and version history */
model ContractSession {
  id            String   @id @default(cuid())
  title         String   @default("Untitled Contract")
  contractType  String   // "rental", "employment", "nda", "service", "custom"
  language      String   @default("fr") // "ar", "fr", "en"
  htmlContent   String   @db.LongText // The live HTML of the contract
  reviewNotes   String?  @db.Text // JSON: last legal review findings
  version       Int      @default(1)
  status        String   @default("draft") // "draft", "finalized"
  metadata      String?  @db.Text // JSON: parties, extracted fields
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      ContractMessage[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/** Newsletter / blog email subscribers */
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  lang      String   @default("ar")   // "ar" | "fr" | "en"
  source    String   @default("blog") // "blog" | "sticky_bar" | "other"
  createdAt DateTime @default(now())
}

/** Individual chat messages within a contract builder session */
model ContractMessage {
  id            String   @id @default(cuid())
  role          String   // "user" | "assistant"
  content       String   @db.Text
  sessionId     String
  session       ContractSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}
